  "network_calls": false,
  "purpose": "Real rollback execution. Restores prior state forward (never destructive), preserves the failed state as evidence, and appends to the transaction + lineage + audit + rollback event stores.",
  "recovery_is_reviewer_authorized": true,
  "replay_is_reviewer_authorized": true,
  "requires_reviewer_confirmation": true,
  "rollback_is_reviewer_authorized": true,
  "rollback_kinds": [
    {
      "action": "copy snapshot of pre-mutation destination state forward into a rollback-target path; mark the failed destination as preserved; emit rollback + lineage + audit events.",
      "deletes_evidence": false,
      "kind": "revert-failed-mutation",
      "preserves_failed_state": true
    },
    {
      "action": "restore staging/incoming/<file> from snapshot; route the failed destination contents into staging/quarantined/<ts>/.",
      "deletes_evidence": false,
      "kind": "revert-failed-staging",
      "preserves_failed_state": true
    },
    {
      "action": "restore prior publication-events pointer from snapshot; mark the regenerated outputs as superseded; do not delete them.",
      "deletes_evidence": false,
      "kind": "revert-publication-regeneration",
      "preserves_failed_state": true
    },
    {
      "action": "restore prior manifest snapshot; append a rollback-record event linking to the failed registration; do not rewrite history.",
      "deletes_evidence": false,
      "kind": "revert-manifest-registration",
      "preserves_failed_state": true
    },
    {
      "action": "copy a reviewer-selected snapshot back into a restore-target tree (NEVER over the live tree directly; reviewer migrates).",
      "deletes_evidence": false,
      "kind": "restore-prior-snapshot",
      "preserves_failed_state": true
    },
    {
      "action": "append a lineage-bridge event referencing both the failed and restored operation_ids; never edit prior lineage events.",
      "deletes_evidence": false,
      "kind": "restore-lineage-continuity",
      "preserves_failed_state": true
    }
  ],
  "rollback_preserves_evidence": true,
  "rules": [
    {
      "fail_closed": true,
      "id": "RBE-1",
      "rule": "rollback_requires_reviewer_authorization"
    },
    {
