    },
    {
      "fail_closed": true,
      "id": "RBE-5",
      "rule": "rollback_must_not_delete_evidence"
    },
    {
      "fail_closed": true,
      "id": "RBE-6",
      "reasoning": "Restored content lands in a rollback-target/ path; reviewer explicitly migrates if desired.",
      "rule": "rollback_must_not_overwrite_live_tree"
    },
    {
      "fail_closed": true,
      "id": "RBE-7",
      "rule": "rollback_must_emit_rollback_lineage_audit_events"
