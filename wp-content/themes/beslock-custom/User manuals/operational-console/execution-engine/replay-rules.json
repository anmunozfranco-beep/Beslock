  "purpose": "Deterministic replay of governed transactions from snapshots + transaction journal + lineage + manifest events. Replay is read-only by default; reviewer-authorized writes only.",
  "recovery_is_reviewer_authorized": true,
  "replay_is_reviewer_authorized": true,
  "replay_modes": [
    {
      "description": "Reconstructs the expected outcome and compares against current state. Emits a replay-finding event. No filesystem mutation.",
      "mode": "verify-only",
      "writes": false
    },
    {
      "description": "Writes the replayed outcome into a rollback-target/ tree (never into the live tree directly).",
      "mode": "reconstruct-into-rollback-target",
      "requires_reviewer_confirm": true,
      "writes": true
    }
  ],
  "requires_reviewer_confirmation": true,
  "rollback_is_reviewer_authorized": true,
  "rollback_preserves_evidence": true,
  "rules": [
    {
      "fail_closed": true,
      "id": "RPL-1",
      "reasoning": "Same inputs must always produce the same replay.",
      "rule": "replay_must_be_deterministic"
    },
    {
      "fail_closed": true,
      "id": "RPL-2",
      "rule": "replay_default_mode_is_read_only"
    },
    {
      "fail_closed": true,
      "id": "RPL-3",
      "rule": "replay_must_consume_only_snapshots_and_event_journals"
    },
    {
      "fail_closed": true,
      "id": "RPL-4",
      "rule": "replay_must_emit_replay_event"
    },
    {
      "fail_closed": true,
      "id": "RPL-5",
      "rule": "replay_writing_mode_requires_reviewer_confirm"
    },
    {
      "fail_closed": true,
      "id": "RPL-6",
      "rule": "replay_must_never_overwrite_live_tree"
    },
    {
      "fail_closed": true,
      "id": "RPL-7",
      "rule": "replay_must_carry_transaction_id_and_replay_id"
    }
  ],
