  "steps": [
    {
      "n": 1,
      "text": "abrir `Smart Life`"
    },
    {
      "n": 2,
      "text": "tocar `+` para `Add device`"
    },
    {
      "n": 3,
      "text": "entrar en `Camera&Lock`"
    },
    {
      "n": 4,
      "text": "elegir `Video Lock (Wi-Fi)`"
    },
    {
      "n": 5,
      "text": "seguir la pantalla `Reset the device`"
    },
    {
      "n": 6,
      "text": "seleccionar la red Wi-Fi e introducir la contrasena"
    },
    {
      "n": 7,
      "text": "poner la cerradura en modo de red"
    },
    {
      "n": 8,
      "text": "apuntar el codigo QR del telefono a la camara de la cerradura"
    },
    {
      "n": 9,
      "text": "cuando la cerradura emita el aviso sonoro, confirmar que se ha oido y esperar el alta"
    }
