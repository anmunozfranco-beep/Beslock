      "menu_path": "Agregar usuario -> Agregar administrador or Agregar usuario",
      "steps": [
        "Enter Agregar usuario.",
        "Choose the user type.",
        "Select Contrasena.",
        "Enter the PIN.",
        "Confirm the PIN.",
        "Save the enrollment.",
        "Test the credential."
      ],
      "validation_checks": [
        "The credential opens correctly.",
        "The user remembers the credential.",
        "The system accepts the credential consistently."
      ],
      "source_refs": [
        "source-of-truth/manuals/e-Orbit user manual.md#5"
