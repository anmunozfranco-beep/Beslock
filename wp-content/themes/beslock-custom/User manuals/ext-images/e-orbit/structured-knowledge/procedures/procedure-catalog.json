    {
      "id": "register-fingerprint",
      "surface": "local-device",
      "menu_path": "Agregar usuario -> Agregar administrador or Agregar usuario",
      "steps": [
        "Enter the menu.",
        "Choose Agregar usuario.",
        "Choose the user type.",
        "Select Huella.",
        "Place the finger when prompted.",
        "Lift and place the same finger repeatedly.",
        "Wait for confirmation.",
        "Test the fingerprint."
      ],
      "validation_checks": [
        "Fingerprint reading is stable.",
        "Access works multiple times in a row.",
        "The user can place the finger naturally."
      ],
      "source_refs": [
        "source-of-truth/manuals/e-Orbit user manual.md#6"
      ]
    },
    {
