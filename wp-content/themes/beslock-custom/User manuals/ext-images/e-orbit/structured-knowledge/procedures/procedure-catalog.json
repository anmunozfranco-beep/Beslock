      "menu_path": "observed numeric flow",
      "steps": [
        "Wake the panel.",
        "Enter 888#.",
        "Enter the language system.",
        "Select the target language.",
        "Use 3009# for Spanish only if the commercial build confirms it.",
        "Confirm the change when prompted."
      ],
      "validation_checks": [
        "The language actually changes.",
        "The user understands the menu.",
        "The lock still responds normally."
      ],
      "validation_status": "hardware-validation-required",
      "source_refs": [
        "source-of-truth/manuals/e-Orbit user manual.md#7",
        "source-of-truth/specifications/e-Orbit_1.xls"
      ]
    },
