      "steps": [
        "Wake the lock panel.",
        "Enter the menu.",
        "Choose Agregar usuario.",
        "Choose Agregar administrador.",
        "Select the credential type.",
        "Complete the enrollment.",
        "Save the result.",
        "Test access immediately."
