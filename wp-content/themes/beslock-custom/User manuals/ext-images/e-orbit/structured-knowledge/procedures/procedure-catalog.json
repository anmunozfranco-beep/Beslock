      "steps": [
        "Wake the lock panel.",
        "Enter the menu.",
        "Choose Agregar usuario.",
        "Choose Agregar usuario again.",
        "Select the credential type.",
        "Complete the enrollment.",
        "Save the result.",
        "Test access."
      ],
      "validation_checks": [
        "Access works.",
