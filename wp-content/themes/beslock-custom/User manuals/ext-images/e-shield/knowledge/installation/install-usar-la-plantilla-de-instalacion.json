  "steps": [
    {
      "n": 1,
      "text": "imprime el PDF original sin ajuste de escala"
    },
    {
      "n": 2,
      "text": "confirma si la hoja visible corresponde a apertura derecha o si debes espejarla para apertura izquierda"
    },
    {
      "n": 3,
      "text": "alinea la referencia de `LATERAL DE PUERTA` exactamente con el canto de la puerta"
    },
    {
      "n": 4,
      "text": "respeta el retiro de borde visible de `60 mm`"
    },
    {
      "n": 5,
      "text": "marca sobre la puerta solo despues de confirmar que la impresion no fue reducida ni ampliada"
    }
