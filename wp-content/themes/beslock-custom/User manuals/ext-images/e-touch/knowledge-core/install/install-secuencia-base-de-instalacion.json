  "steps": [
    {
      "n": 1,
      "text": "pasa el eje cuadrado junto con el cableado por el cuerpo de la cerradura"
    },
    {
      "n": 2,
      "text": "ajusta la posicion del orificio segun la posicion real del lock body"
    },
    {
      "n": 3,
      "text": "selecciona los tornillos segun el grosor de la puerta y aprietalos"
    },
    {
      "n": 4,
      "text": "abre la tapa de baterias para preparar la alimentacion interior"
    },
    {
      "n": 5,
      "text": "instala el `deadbolt`"
    },
    {
      "n": 6,
      "text": "instala y fija la manija en la puerta"
    },
    {
      "n": 7,
      "text": "conecta el puerto del circuito del lock"
    },
    {
      "n": 8,
      "text": "aprieta los tornillos y asegura la tapa de baterias"
    }
  ],
