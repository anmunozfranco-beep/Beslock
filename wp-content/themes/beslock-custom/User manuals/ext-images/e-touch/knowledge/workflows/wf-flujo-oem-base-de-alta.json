    {
      "n": 1,
      "text": "abrir `Tuya Smart` o `Smart Life`"
    },
    {
      "n": 2,
      "text": "tocar `Add device`"
    },
    {
      "n": 3,
      "text": "entrar a `Security monitoring`"
    },
    {
      "n": 4,
      "text": "elegir `Smart Door Lock`"
    },
    {
